#: templates/core/home.html:4
msgid "Home"
msgstr "Start (zdrajco)"

#: templates/core/home.html:19
msgid "Sign out"
msgstr "Wyloguj się"

#: templates/core/home.html:27
#, python-format
msgid "Hi, %(username)s! 👋"
msgstr "Cześć, %(username)s, ty zdrajco! 👋 A na wesele jednak nie przyjedziesz?"

#: templates/core/home.html:29
msgid "You have signed in successfully. Your pool will go here."
msgstr ""
"Zalogowano. Szkoda, że z Polski nie ruszysz się na wesele kolegi, co? "
"Zdrajca jeden."

#: templates/registration/login.html:4 templates/registration/login.html:116
msgid "Sign in"
msgstr "Zaloguj się"

#: templates/registration/login.html:30
msgid "Live the World Cup<br>like never before."
msgstr "Oglądaj mundial z Polski,<br>skoro na wesele i tak nie przyjedziesz."

#: templates/registration/login.html:33
msgid "Yenko's got this."
msgstr "Yenko, zdrajco — wesele bez Ciebie to nie to samo."

#: templates/registration/login.html:57
msgid "Welcome back"
msgstr "Witaj z powrotem, zdrajco"

#: templates/registration/login.html:58
msgid "Sign in to continue with your pool."
msgstr "Zaloguj się i typuj mecze... bo na wesele i tak nie dotrzesz."

#: templates/registration/login.html:73
msgid "Username"
msgstr "Nazwa użytkownika"

#: templates/registration/login.html:77
msgid "your_username"
msgstr "twoja_nazwa"

#: templates/registration/login.html:90
msgid "Password"
msgstr "Hasło"

#: templates/registration/login.html:92
msgid "Forgot it?"
msgstr "Zapomniałeś? (jak o weselu)"

#: templates/registration/login.html:108
msgid "Keep me signed in"
msgstr "Zapamiętaj mnie (w przeciwieństwie do Ciebie)"

#: templates/registration/login.html:121
msgid "Don't have an account?"
msgstr "Nie masz konta?"

#: templates/registration/login.html:122
msgid "Sign up"
msgstr "Zarejestruj się"
