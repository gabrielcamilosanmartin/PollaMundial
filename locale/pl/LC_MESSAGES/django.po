#: predictions/templates/predictions/home.html:4
#: predictions/templates/predictions/home.html:7
#: templates/dashboard_base.html:18
msgid "Matches"
msgstr "Mecze"

#: predictions/templates/predictions/home.html:8
msgid "Predict the score of each match before it starts."
msgstr ""
"Typuj wynik każdego meczu, zanim się zacznie (jeśli zdążysz między wymówkami "
"od wesela, zdrajco)."

#: predictions/templates/predictions/home.html:12
msgid "Your predictions were saved."
msgstr "Twoje typy zapisano."

#: predictions/templates/predictions/home.html:22
#: predictions/templates/predictions/my_predictions.html:16
#: predictions/templates/predictions/results.html:40
msgid "Match"
msgstr "Mecz"

#: predictions/templates/predictions/home.html:23
msgid "Date"
msgstr "Data"

#: predictions/templates/predictions/home.html:24
msgid "Stage"
msgstr "Faza"

#: predictions/templates/predictions/home.html:25
msgid "Your prediction"
msgstr "Twój typ"

#: predictions/templates/predictions/home.html:45
msgid "Closed"
msgstr "Zamknięte"

#: predictions/templates/predictions/home.html:66
msgid "There are no matches yet."
msgstr "Nie ma jeszcze meczów."

#: predictions/templates/predictions/home.html:79
msgid "Save predictions"
msgstr "Zapisz typy"

#: predictions/templates/predictions/my_predictions.html:4
#: predictions/templates/predictions/my_predictions.html:7
#: templates/dashboard_base.html:22
msgid "My predictions"
msgstr "Moje typy"

#: predictions/templates/predictions/my_predictions.html:9
msgid "Predictions of all participants for the matches that have finished."
msgstr "Typy wszystkich uczestników dla zakończonych meczów."

#: predictions/templates/predictions/my_predictions.html:17
#: predictions/templates/predictions/results.html:41
msgid "Result"
msgstr "Wynik"

#: predictions/templates/predictions/my_predictions.html:41
msgid "There are no finished matches yet."
msgstr "Nie ma jeszcze zakończonych meczów."

#: predictions/templates/predictions/results.html:4
#: predictions/templates/predictions/results.html:7
#: templates/dashboard_base.html:26
msgid "Results"
msgstr "Wyniki"

#: predictions/templates/predictions/results.html:9
msgid ""
"Match results and points per participant (1 point for the winner, 3 for the "
"exact score)."
msgstr ""
"Wyniki meczów i punkty uczestników (1 pkt za zwycięzcę, 3 za dokładny wynik)."

#: predictions/templates/predictions/results.html:14
msgid "The results could not be updated from the API."
msgstr "Nie udało się zaktualizować wyników z API."

#: predictions/templates/predictions/results.html:20
msgid "Standings"
msgstr "Klasyfikacja (Yenko i tak na końcu, bo zdrajca)."

#: predictions/templates/predictions/results.html:26
msgid "pts"
msgstr "pkt"

#: predictions/templates/predictions/results.html:29
msgid "There are no results yet."
msgstr "Nie ma jeszcze wyników."

#: templates/dashboard_base.html:67
msgid "Sign out"
msgstr "Wyloguj się"

#: templates/registration/login.html:4 templates/registration/login.html:121
msgid "Sign in"
msgstr "Zaloguj się"

#: templates/registration/login.html:35
msgid "Live the World Cup<br>like never before."
msgstr "Oglądaj mundial z Polski,<br>skoro na wesele i tak nie przyjedziesz."

#: templates/registration/login.html:38
msgid "Yenko's got this."
msgstr "Yenko, zdrajco — wesele bez Ciebie to nie to samo."

#: templates/registration/login.html:62
msgid "Welcome back"
msgstr "Witaj z powrotem, zdrajco"

#: templates/registration/login.html:63
msgid "Sign in to continue with your pool."
msgstr "Zaloguj się i typuj mecze... bo na wesele i tak nie dotrzesz."

#: templates/registration/login.html:78
msgid "Email"
msgstr "E-mail (zdrajco)"

#: templates/registration/login.html:95
msgid "Password"
msgstr "Hasło"

#: templates/registration/login.html:97
msgid "Forgot it?"
msgstr "Zapomniałeś? (jak o weselu)"

#: templates/registration/login.html:113
msgid "Keep me signed in"
msgstr "Zapamiętaj mnie (w przeciwieństwie do Ciebie)"

#: templates/registration/login.html:126
msgid "Don't have an account?"
msgstr "Nie masz konta?"

#: templates/registration/login.html:127
msgid "Sign up"
msgstr "Zarejestruj się"

